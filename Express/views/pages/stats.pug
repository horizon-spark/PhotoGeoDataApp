extends ../layout.pug

block title     
    title #{title}

block content 
    h1 Статистика загрузок
        div(id="stats") Загрузка...
        
    h3 Последние 10 загрузок
    table
        tr
            th Файл
            th Дата
            th GPS
            th Посмотреть на карте

        each upload in recentUploads
            tr
                td #{upload.fileName}
                td #{upload.uploadDate.toLocaleString()}

                if upload.coordinates.lat && upload.coordinates.lon 
                    td #{upload.coordinates.lat}:#{upload.coordinates.lon}
                else 
                    td Координаты не найдены

                td 
                    a(href=`/upload/${upload.id}`) Просмотр
    br
    a(href="/") Назад
    script.
        fetch('/api/stats')
        .then(r => r.json())
        .then(s => {
            document.getElementById('stats').innerHTML = `
            <p>Всего загрузок: ${s.totalUploads}</p>
            <p>С GPS: ${s.filesWithGps} (${s.percentWithGps?.toFixed(1)}%)</p>
            <p>Ср. размер: ${s.avgFileSizeMB?.toFixed(2)} MB</p>
            <p>Уникальных посетителей: ${s.uniqueVisitors}</p>
            `;
        });
